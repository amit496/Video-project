# OpenAI (optional for script, AI story images, SEO)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Script provider: openai | gemini | template
# - template: no API, RSS headlines/summaries se local script banega
SCRIPT_PROVIDER=template

# SEO provider (only used when SEO_METADATA_USE_LLM=1): openai | gemini
SEO_PROVIDER=openai

# B-roll source: localai | runway | article | generated | openai | local
# - localai: fully local topic-driven image generation, no API
# - runway: real AI image generation + image-to-video via Runway API
# - article: fetch article-page image and auto-create short clip
# - generated: local story cards + short clips from news text (no API)
# - openai: headline-based unique images — uses OpenAI Images API ($)
# - local: only assets/news_today/
BROLL_SOURCE=localai

RUNWAY_API_KEY=
RUNWAY_IMAGE_MODEL=gen4_image
RUNWAY_VIDEO_MODEL=gen4.5
RUNWAY_RATIO=1280:720
RUNWAY_DURATION_SEC=5

OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1792x1024

SEO_METADATA_USE_LLM=0
OPENAI_SEO_MODEL=gpt-4o-mini

LIPSYNC_ENABLE=0
SADTALKER_DIR=
SADTALKER_PYTHON=

TARGET_DURATION_SEC=900
EDGE_TTS_VOICE=en-IN-NeerjaNeural

# BACKGROUND_MUSIC=./path/to/one.mp3
BACKGROUND_MUSIC_VOLUME=0.12

ANCHOR_IMAGE_DIR=./assets/anchor
NEWS_MEDIA_DIR=./assets/news_today
NEWS_MUSIC_DIR=./assets/news_music
OUTPUT_DIR=./output
TEMP_DIR=./temp

YOUTUBE_CLIENT_SECRETS=./secrets/client_secret.json
YOUTUBE_TOKEN_PICKLE=./secrets/youtube_token.pickle
